---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/events/", label: "Events" },
  { href: "/resources/", label: "Resources" },
  { href: "/contact/", label: "Contact" },
] as const;

function isActive(href: string) {
  if (href === "/") return pathname === "/" || pathname === "";
  return pathname.startsWith(href);
}
---

<header class="border-b border-brand-teal/10 bg-white/90 backdrop-blur-sm">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6"
  >
    <a
      href="/"
      class="group flex items-center gap-3 rounded-2xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-teal"
      aria-label="NDMDs — Neurodiversity in Medicine Society, home"
    >
      <img
        src="/ndmds-logo.png"
        alt=""
        width="56"
        height="56"
        class="h-14 w-14 shrink-0 transition-transform group-hover:scale-[1.02]"
        loading="eager"
        decoding="async"
      />
      <div class="leading-tight">
        <span class="block text-lg font-extrabold text-brand-teal">NDMDs</span>
        <span class="text-sm font-semibold text-brand-teal/80"
          >Neurodiversity in Medicine</span
        >
      </div>
    </a>
    <nav aria-label="Primary">
      <ul class="flex flex-wrap items-center gap-1 sm:gap-2">
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  "rounded-full px-3 py-2 text-sm font-semibold transition-colors sm:px-4",
                  isActive(href)
                    ? "bg-brand-teal text-white"
                    : "text-brand-teal hover:bg-brand-surface",
                ]}
                aria-current={isActive(href) ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
