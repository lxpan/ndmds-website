---
import PageLayout from "../layouts/PageLayout.astro";

const myths = [
  {
    myth: "Neurodivergence is primarily a disorder to diagnose and treat.",
    reality:
      "Many neurodivergent people experience their cognition as an identity as well as a clinical label. Care may focus less on correcting difference and more on supporting functioning, wellbeing, and environment fit.",
  },
  {
    myth: "Difficulty with social norms implies lack of empathy.",
    reality:
      "Empathy is usually present but expressed or processed differently. Miscommunication between neurotypical and neurodivergent people is often bidirectional, not a deficit in one person.",
  },
  {
    myth: "Neurodivergence is rare and clinically obvious.",
    reality:
      "Many people reach adulthood — including medical training — without diagnosis while adapting to systems designed for different cognitive styles.",
  },
  {
    myth: "Outward independence reflects internal capacity.",
    reality:
      'Some individuals appear "high functioning" while managing substantial cognitive load from masking, sensory processing, or executive functioning demands.',
  },
  {
    myth: "Standard learning and clinical environments are neutral.",
    reality:
      "Many environments favour specific cognitive styles. What appears to be an individual difficulty may sometimes reflect an environmental mismatch.",
  },
  {
    myth: "Support requires specialised interventions.",
    reality:
      "Helpful adjustments are frequently simple — clear expectations, predictable structure, reduced sensory overload, flexibility in communication.",
  },
] as const;
---

<PageLayout
  title="About"
  description="Vision, values, and who we are — NDMDs Neurodiversity in Medicine Society at the University of Melbourne."
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="max-w-3xl">
      <h1 class="text-4xl font-extrabold text-brand-teal sm:text-5xl">About us</h1>
      <p class="mt-4 text-lg text-brand-teal/90">
        A private space for <abbr title="neurodivergent">ND</abbr>/<abbr
          title="neurodivergent-questioning">NDq</abbr
        >
        Unimelb medical students, hosted by the Neurodiversity in Medicine Society — an
        official UMMSS club and soon to be GSA-affiliated.
      </p>
    </header>

    <section class="mt-12" aria-labelledby="vision-heading">
      <h2 id="vision-heading" class="text-2xl font-extrabold text-brand-teal">
        Our vision
      </h2>
      <ol class="mt-6 list-decimal space-y-3 pl-6 text-lg text-brand-teal/90 marker:font-bold marker:text-brand-teal">
        <li>
          Engage and support neurodiverse medical students (diagnosed and questioning)
          through creating safe online and in-person spaces.
        </li>
        <li>
          Foster self-knowledge for neurodiverse students and education about
          neurodiversity for allies.
        </li>
        <li>
          Provide a platform for peer support between neurodiverse medical students.
        </li>
        <li>
          Advocate for neurodiverse students with regard to how medical education is
          delivered.
        </li>
        <li>
          Advocate for the needs of neurodiverse patients within the Doctor of Medicine
          curriculum.
        </li>
        <li>
          Aim for at least two events per calendar year: one for members only, and one
          for members and any party with an established relationship with the Melbourne
          Medical School for education and allyship.
        </li>
      </ol>
    </section>

    <section class="mt-14" aria-labelledby="neurodiversity-heading">
      <h2 id="neurodiversity-heading" class="text-2xl font-extrabold text-brand-teal">
        What is neurodiversity?
      </h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Understanding different minds</h3>
          <p class="mt-3 text-brand-teal/90">
            The term was coined by sociologist Judy Singer in 1998. Neurodiversity refers
            to the natural variation in human brains. Just as biodiversity describes
            diversity in ecosystems, neurodiversity recognises diversity in thinking,
            learning, attention, communication, social interaction, movement, and sensory
            experiences.
          </p>
        </div>
        <div class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Neurodivergent thinking</h3>
          <p class="mt-3 text-brand-teal/90">
            Neurodivergent describes people whose cognitive styles differ from dominant
            societal expectations. Common examples include autism, ADHD, dyslexia,
            dyspraxia, dyscalculia, Tourette syndrome, and OCD. Many appear in the DSM-5,
            but the neurodiversity framework emphasises difference, not deficit.
          </p>
        </div>
        <div class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Why this matters</h3>
          <p class="mt-3 text-brand-teal/90">
            Historically, cognitive differences were framed mainly as mental illness,
            intellectual disability, or developmental disorder. Neurodiversity reframes
            these differences as natural neurological variation, experiences shaped by
            social environments, and a mix of strengths and challenges.
          </p>
        </div>
      </div>

      <figure class="mt-10">
        <img
          src="/images/understanding-different-minds.png"
          alt="Infographic: three columns on neurodiversity, neurodivergent thinking, and why it matters, with the NDMDs logo"
          width={1200}
          height={800}
          class="w-full max-w-4xl rounded-2xl border border-brand-teal/10 bg-white p-2 shadow-sm"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="mt-3 max-w-3xl text-sm text-brand-teal/75">
          Society infographic — understanding different minds, neurodivergent thinking,
          and why inclusion matters.
        </figcaption>
      </figure>
    </section>

    <section class="mt-14" aria-labelledby="lived-heading">
      <h2 id="lived-heading" class="text-2xl font-extrabold text-brand-teal">
        Lived experience
      </h2>
      <p class="mt-4 max-w-3xl text-lg text-brand-teal/90">
        For many people, recognising neurodivergence can be:
      </p>
      <ul class="mt-4 max-w-3xl list-disc space-y-2 pl-6 text-lg text-brand-teal/90 marker:text-brand-teal">
        <li>A moment of clarity, where past experiences suddenly make sense.</li>
        <li>A pathway to meeting others who share similar experiences.</li>
        <li>
          Emotionally complex — with relief, pride, uncertainty, or stigma, sometimes all
          at once.
        </li>
      </ul>
      <p class="mt-6 max-w-3xl text-lg text-brand-teal/90">
        Neurodiversity reminds us that different brains are part of normal human
        variation. Social structures shape whether differences become barriers; only
        understanding diversity improves inclusion.
      </p>

      <figure class="mt-10">
        <img
          src="/images/lived-experience.png"
          alt="Infographic: lived experience, conclusion, follow us and join the conversation, with QR codes for member signup and Facebook"
          width={1200}
          height={800}
          class="w-full max-w-4xl rounded-2xl border border-brand-teal/10 bg-white p-2 shadow-sm"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="mt-3 max-w-3xl text-sm text-brand-teal/75">
          Lived experience, conclusion, and ways to connect (QR codes point to the same
          destinations as our <a class="underline decoration-brand-cyan underline-offset-2" href="/contact/"
            >contact page</a
          > when forms and links are live).
        </figcaption>
      </figure>
    </section>

    <section
      class="mt-14"
      aria-labelledby="myth-heading"
      id="mythbusting"
    >
      <h2 id="myth-heading" class="text-2xl font-extrabold text-brand-teal">
        Mythbusting
      </h2>
      <p class="mt-4 max-w-3xl text-brand-teal/90">
        Six myths and realities from our society poster. Expand each row to read the
        full reality — or scan the list on a small screen.
      </p>
      <div class="mt-8 space-y-3">
        {
          myths.map((item, i) => (
            <details class="myth-details group rounded-2xl border border-brand-teal/20 bg-white shadow-sm open:border-brand-cyan/35 open:ring-2 open:ring-brand-cyan/25">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-3 rounded-2xl bg-gradient-to-r from-brand-teal/[0.07] to-brand-cyan/20 px-4 py-4 text-left font-semibold text-brand-teal transition hover:from-brand-teal/10 hover:to-brand-cyan/25 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-teal">
                <span>
                  <span class="mr-2 inline-flex h-6 min-w-[1.75rem] items-center justify-center rounded-full bg-brand-teal text-xs font-bold text-white">
                    {i + 1}
                  </span>
                  <span class="text-brand-teal/95">Myth: {item.myth}</span>
                </span>
                <span
                  class="mt-0.5 shrink-0 text-brand-teal/60 transition group-open:rotate-180"
                  aria-hidden="true"
                >
                  ▼
                </span>
              </summary>
              <div class="border-t border-brand-cyan/25 bg-brand-surface/95 px-4 py-4 text-brand-teal/90">
                <p class="text-xs font-bold uppercase tracking-wide text-brand-cyan/90">
                  Reality
                </p>
                <p class="mt-2 leading-relaxed">{item.reality}</p>
              </div>
            </details>
          ))
        }
      </div>
    </section>

    <section class="mt-14" aria-labelledby="philosophy-heading">
      <h2 id="philosophy-heading" class="text-2xl font-extrabold text-brand-teal">
        How we think about definition
      </h2>
      <blockquote
        class="mt-6 border-l-4 border-brand-cyan pl-5 text-lg italic text-brand-teal/90"
      >
        <p>
          In academic literature, the power to define a group and its members is called
          <cite class="font-semibold not-italic">epistemological authority</cite>. The
          neurodivergent community has often had to fight to retain it, when diagnosis is
          expensive, slow, and framed around deficit. Here, you define your own
          experiences — we are peers, not gatekeepers.
        </p>
      </blockquote>
    </section>

    <section class="mt-14" aria-labelledby="values-heading">
      <h2 id="values-heading" class="text-2xl font-extrabold text-brand-teal">
        Values
      </h2>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2">
        <li class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Inclusion</h3>
          <p class="mt-2 text-brand-teal/85">
            You are welcome whether your journey is medicalised or not, and whether you
            use identity-first or person-first language — we respect how you describe
            yourself.
          </p>
        </li>
        <li class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Solidarity</h3>
          <p class="mt-2 text-brand-teal/85">
            We stand with neurodivergent students and patients, and we work for teaching
            and care that does not treat difference as deficit.
          </p>
        </li>
        <li class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Peer support</h3>
          <p class="mt-2 text-brand-teal/85">
            We aim to hold space with curiosity and without judgement — including
            anonymous sharing when that helps people feel safe.
          </p>
        </li>
        <li class="rounded-2xl border border-brand-teal/10 bg-brand-surface p-6">
          <h3 class="font-bold text-brand-teal">Transparency</h3>
          <p class="mt-2 text-brand-teal/85">
            We are clear about what we can and cannot do, and we signpost to professional
            and University support when that is what you need.
          </p>
        </li>
      </ul>
    </section>

    <section class="mt-14" aria-labelledby="who-heading">
      <h2 id="who-heading" class="text-2xl font-extrabold text-brand-teal">
        Who we are
      </h2>
      <p class="mt-4 max-w-3xl text-lg text-brand-teal/90">
        We are MD students volunteering our time. We are not clinicians; we do not
        provide diagnosis or treatment. We offer community, shared experience, and
        pointers to official resources when that helps.
      </p>
      <p class="mt-4 max-w-3xl text-lg text-brand-teal/90">
        NDMDs is affiliated with the University of Melbourne Medical Students Society
        (UMMSS). New committee members are welcome as roles become available — say hello
        via our <a
          class="font-semibold text-brand-teal underline decoration-brand-cyan underline-offset-2 hover:decoration-brand-teal"
          href="/contact/">contact page</a
        >. For practical links, see our <a
          class="font-semibold text-brand-teal underline decoration-brand-cyan underline-offset-2 hover:decoration-brand-teal"
          href="/resources/">resources</a
        > page.
      </p>
    </section>
  </div>
</PageLayout>
